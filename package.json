{
  "name": "mcp-nixos-ops",
  "version": "1.0.0",
  "description": "MCP server for remote NixOS system management via SSH",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "mcp-nixos-ops": "src/index.ts"
  },
