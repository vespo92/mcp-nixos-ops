  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/bun": "^1.2.13",
    "typescript": "^5.8.3"
  }
}
